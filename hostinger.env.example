# =============================================================================
# Hostinger → Deployments
# =============================================================================
#
# ⚠️  IMPORTANTE: no painel, mude o Framework de "Vite" para "Other".
#     Vite = só frontend estático (sem API). Other = Node.js com backend.
#
# CONFIGURAÇÃO DO PAINEL:
#
#   Framework:         Other
#   Entry file:        server.mjs
#   Build command:     npm run build:hostinger
#   Start command:     npm start
#   Output directory:  dist
#   Package manager:   npm
#
# Teste após deploy: https://SEU-DOMINIO/api/health
# Deve retornar JSON: {"status":"ok",...}
#
# =============================================================================

NODE_ENV=production
SERVE_STATIC=true

# NÃO defina PORT — o Hostinger injeta a porta correta.

JWT_SECRET=coloque_um_segredo_longo_aleatorio_aqui

SUPABASE_URL=https://jkfindoajtuagdfarszb.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://jkfindoajtuagdfarszb.supabase.co/auth/v1/.well-known/jwks.json
