# =============================================================================
# Hostinger → Deployments → Environment variables
# https://hpanel.hostinger.com/websites/lightpink-termite-509022.hostingersite.com/deployments
# =============================================================================
#
# CONFIGURAÇÃO DO PAINEL (obrigatório):
#
#   Build command:     npm run build:hostinger
#   Start command:     npm start          ← SEM ISSO SÓ SOBE O FRONTEND (dist/)
#   Output directory:  dist
#   Package manager:   npm
#
# Após deploy, teste: https://SEU-DOMINIO/api/health
# Deve retornar JSON: {"status":"ok",...}  — NÃO a página 404 do React
#
# =============================================================================

NODE_ENV=production
SERVE_STATIC=true

# NÃO defina PORT manualmente — o Hostinger injeta a porta correta.
# Remova PORT=3001 se estiver nas variáveis.

# Nome EXATO da variável (não use JWT_SECR):
JWT_SECRET=coloque_um_segredo_longo_aleatorio_aqui

SUPABASE_URL=https://jkfindoajtuagdfarszb.supabase.co

# Formato novo (recomendado):
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://jkfindoajtuagdfarszb.supabase.co/auth/v1/.well-known/jwks.json

# Formato legado (alternativa):
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
