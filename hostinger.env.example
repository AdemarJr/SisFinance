# =============================================================================
# Hostinger → Deployments → Settings
# =============================================================================
#
# ⚠️  Framework DEVE ser "Other" (NÃO "Vite" — Vite = só HTML, sem API)
#
#   Framework:         Other
#   Entry file:        app.js
#   Build command:     npm run build:hostinger
#   Start command:     npm start
#   Output directory:  dist
#   Node.js version:   20.x ou 22.x
#
# Variáveis de ambiente (Deployments → Environment variables):
#
NODE_ENV=production
SERVE_STATIC=true

JWT_SECRET=segredo_longo_aleatorio

SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# NÃO defina PORT — o Hostinger injeta automaticamente.
# NÃO use JWT_SECR — o nome correto é JWT_SECRET.
#
# Após deploy, teste:
#   https://SEU-DOMINIO/api/health  → JSON {"status":"ok",...}
#
# Se /api/health der 404:
#   1. Settings → Framework = Other, Entry = app.js, Start = npm start
#   2. Redeploy
#   3. Dashboard → Restart (botão Running)
#   4. Veja os logs de deploy — deve aparecer "SisFinance API na porta ..."
# =============================================================================
